    "jsdom": "^29.0.2",
    "openapi-typescript": "^6.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.2.0",
    "vite-plugin-solid": "^2.10.0",
    "vitest": "^1.4.0"
